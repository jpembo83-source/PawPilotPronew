# Frontend (Vite) environment variables — read via import.meta.env at build time
# and shipped to the browser, so PUBLIC values only (the Supabase anon key is
# safe to expose; it is protected by Row Level Security). NEVER put the
# service-role key here.
#
# Set these per Netlify deploy context so each environment targets the right
# Supabase project (see deploy-workflow/RUNBOOK.md):
#   production              -> prod    (ruahrxkfgfyshuxykiay)
#   deploy-preview / branch -> staging (ihdbnwlmqhsrslstbbqn)
#
# The central client (utils/supabase/info.ts) uses PROJECT_ID; several feature
# modules build URLs from VITE_SUPABASE_URL directly, so set both.

VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
