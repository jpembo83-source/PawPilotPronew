  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "typecheck:check": "node scripts/typecheck-baseline.mjs check",
    "typecheck:baseline": "node scripts/typecheck-baseline.mjs record",
    "typecheck:server": "deno check supabase/functions/server/index.tsx",
    "lint": "eslint .",
    "lint:check": "node scripts/lint-baseline.mjs check",
    "lint:baseline": "node scripts/lint-baseline.mjs record",
